# Backend API base URL.
# The Vite dev proxy forwards all /api/* requests to this target so the browser
# never crosses origins. Copy this file to .env.local and adjust as needed.
#
# Inside Docker Compose (default): use the compose service name.
VITE_API_BASE_URL=http://finiex-dev:8000
#
# Host-only dev (no Docker): use localhost.
# VITE_API_BASE_URL=http://localhost:8000
